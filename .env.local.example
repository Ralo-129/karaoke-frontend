# URL of the karaoke-backend (used by the Next.js API routes, server-side).
# Local: http://localhost:8000  |  Hosted: your backend's public URL.
BACKEND_URL=http://localhost:8000

# Must match the backend's ADMIN_TOKEN. Forwarded server-side as X-Admin-Token
# when deleting songs. Kept out of the browser bundle (no NEXT_PUBLIC_ prefix).
ADMIN_TOKEN=change-me-to-a-long-random-string

# Supabase: lets the catalog load directly from Supabase, so browsing/playing
# works even when the backend is off. Use the project URL + the ANON (public)
# key — never the service role key here. If you leave these empty, the app
# falls back to reading the catalog through the backend.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
